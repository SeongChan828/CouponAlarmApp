{
  "expo": {
    "name": "쿠폰 알림",
    "slug": "coupon-alarm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FF5B4A"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF5B4A"
      },
      "package": "com.anonymous.couponalarmapp",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.couponalarmapp",
      "infoPlist": {
        "NSCameraUsageDescription": "바코드 스캔을 위해 카메라를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "쿠폰 이미지 저장을 위해 사진 라이브러리에 접근합니다."
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-asset"
    ]
  }
}
